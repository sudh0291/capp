# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=platform_user
DB_PASS=your_secure_password
DB_NAME=coding_platform

# Redis Configuration (app-level cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Redis Configuration (Bull job queue — separate instance, noeviction)
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379

# External Services
JUDGE0_URL=http://localhost:2358  # Docker: overridden to http://judge0-server:2358 in docker-compose.yml
CHROMA_URL=http://localhost:8000

# AI Models (Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=codego-generator           # Used for question generation (can be heavier)
OLLAMA_GRADING_MODEL=qwen2.5-coder:1.5b # Used for fast code grading (2-5 second response)

# Mistral AI Configuration
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# Server Configuration
PORT=3000
UV_THREADPOOL_SIZE=16
